# Define the job for a worker
jloop = function(ichunk) {
tot = 0;   nr = nrow(lnks)  #lnks global at worker
for (i in ichunk) {
tmp = lnks[(i+1):nr,] %*% lnks[i,]
tot = tot + sum(tmp)
}
tot/nr
}
# set up a cluster of nworkers workers on a multicore machine
library(parallel)
initmc <- function(nworkers) {
makeCluster(nworkers)
}
cl2 = initmc(4)
#################### chunking
mutoutparChunk = function(cls) {
nr = nrow(lnks)  # lnks global at manager
clusterExport(cls,"lnks")
ichunks =clusterSplit(cls, 1:(nr-1))  #was 1:(nr-1)
tots = clusterApply(cls,ichunks,jloop)
Reduce(sum,tots) / nr
}
simChunk = function(nr,nc,cls) {
lnks<<-matrix(sample(0:1,(nr*nc),replace=TRUE),nrow=nr)
print(system.time(mutoutparChunk(cls)))
}
# Run the simulation on the 4 nodes
simChunk(500, 500, cl2)
simChunk(2000, 2000, cl2)
mutoutparDyn = function(cls) {
nr = nrow(lnks)  # lnks global at manager
clusterExport(cls,"lnks")
ichunks = 1:(nr-1)
tots = clusterApplyLB(cls,ichunks,jloop)
Reduce(sum,tots) / nr
}
simDyn = function(nr,nc,cls) {
lnks<<-matrix(sample(0:1,(nr*nc),replace=TRUE),nrow=nr)
print(system.time(mutoutparDyn(cls)))
}
# Run the simulation on the 4 nodes
simDyn(500, 500, cl2)
simDyn(2000, 2000, cl2)
mutoutparRevStatic = function(cls) {
nr = nrow(lnks)  # lnks global at manager
clusterExport(cls,"lnks")
ichunks = (nr-1):1
tots = clusterApply(cls,ichunks,jloop)
Reduce(sum,tots) / nr
}
simRevStatic = function(nr,nc,cls) {
lnks<<-matrix(sample(0:1,(nr*nc),replace=TRUE),nrow=nr)
print(system.time(mutoutparRevStatic(cls)))
}
# Run the simulation on the 4 nodes
simRevStatic(500, 500, cl2)
simRevStatic(2000, 2000, cl2)
mutoutparRevDyn = function(cls) {
nr = nrow(lnks)  # lnks global at manager
clusterExport(cls,"lnks")
ichunks = (nr-1):1
tots = clusterApplyLB(cls,ichunks,jloop)
Reduce(sum,tots) / nr
}
simRevDyn = function(nr,nc,cls) {
lnks<<-matrix(sample(0:1,(nr*nc),replace=TRUE),nrow=nr)
print(system.time(mutoutparRevDyn(cls)))
}
# Run the simulation on the 4 nodes
simRevDyn(500, 500, cl2)
simRevDyn(2000, 2000, cl2)
